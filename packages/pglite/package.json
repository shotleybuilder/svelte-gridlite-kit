{
  "name": "@shotleybuilder/gridlite-adapter-pglite",
  "version": "0.5.0",
  "description": "PGLite adapter for svelte-gridlite-kit",
  "author": "Sertantai",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shotleybuilder/svelte-gridlite-kit.git",
    "directory": "packages/pglite"
  },
  "type": "module",
  "types": "./dist/index.d.ts",
