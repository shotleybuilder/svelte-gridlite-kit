{
  "name": "svelte-gridlite-kit-monorepo",
  "private": true,
  "description": "Monorepo for svelte-gridlite-kit packages",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shotleybuilder/svelte-gridlite-kit.git"
  },
  "scripts": {
    "dev": "pnpm --filter gridlite-demo dev",
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "test:run": "pnpm -r test:run",
    "check": "pnpm -r check",
    "lint": "pnpm -r lint",
    "format": "pnpm -r format",
    "package": "pnpm --filter @shotleybuilder/svelte-gridlite-kit package"
  },
  "engines": {
    "node": ">=18"
  }
}
